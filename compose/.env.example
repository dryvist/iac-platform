# Copy to compose/.env (gitignored) and keep it non-secret: image pins, ports,
# identifiers. Real-domain values (DOMAIN, TK_OUTPUT_ENDPOINT, DEPLOY_HOST,
# SEMAPHORE_ADMIN_EMAIL) and every runtime secret come from OpenBao
# (secret/platform/terrakube/main) via scripts/openbao-exec-env.sh at deploy
# time — never in this file.

# Image pins (renovate-tracked)
TK_VERSION=2.28.0
TK_DEX_VERSION=v2.42.0
TK_REDIS_VERSION=8-alpine
TK_POSTGRESQL_VERSION=17
SEMAPHORE_VERSION=v2.18.18

# Host ports Traefik backs onto — must match iac_platform_ports in
# terraform-proxmox constants.tf (the ingress rows reference those constants).
PORT_TERRAKUBE_UI=28080
PORT_TERRAKUBE_API=28081
PORT_TERRAKUBE_REGISTRY=28082
PORT_TERRAKUBE_DEX=28083
PORT_SEMAPHORE=28084

# Terrakube database + storage identifiers (values, not credentials).
TK_POSTGRESQL_USERNAME=terrakube
TK_POSTGRESQL_DATABASE_NAME=terrakubedb
TK_OUTPUT_BUCKET_NAME=terrakube
TK_OUTPUT_STORAGE_REGION=us-east-1
TK_OUTPUT_BUCKET_REGION=us-east-1

# Terrakube admin group in the dex github connector's "org:team-slug" shape.
TERRAKUBE_ADMIN_GROUP=dryvist:terrakube-admins
